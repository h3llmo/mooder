# ─────────────────────────────────────────────────────────────────────────────
# Corporate (PwC) local overrides — NOT committed (see .gitignore)
#
# Switches frontend and backend to their Dockerfile.pwc variants, which pull
# dependencies through the corporate Artifactory proxy instead of public registries.
#
# Usage:
#   1. Copy this file to docker-compose.override.yml  (gitignored — never commit)
#   2. Set the env vars before running docker compose:
#        $env:NPMRC_FILE     = "$env:USERPROFILE\.npmrc"
#        $env:MAVEN_SETTINGS = "C:\dev\tools\apache-maven-3.8.6\conf\settings.xml"
#   3. docker compose up --build -d
#
# See infra/maven/settings.xml.example for the expected settings.xml format.
# ─────────────────────────────────────────────────────────────────────────────

secrets:
  npmrc:
    file: ${NPMRC_FILE}
  maven_settings:
    file: ${MAVEN_SETTINGS}

services:
  frontend:
    build:
      dockerfile: Dockerfile.pwc
      secrets:
        - npmrc
  backend:
    build:
      dockerfile: Dockerfile.pwc
      secrets:
        - maven_settings
