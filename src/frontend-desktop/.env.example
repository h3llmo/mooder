# ── Server-side only — never commit real values ──────────────────────────────
# Copy this file to .env.local for local development outside docker.
# In docker, these are injected by docker-compose environment: blocks.

# Internal URL of the backend (docker service name or localhost)
MOODER_API_URL=http://backend:8080

# OIDC — Keycloak on local, Auth0 on stg/prod (ADR-004)
OIDC_ISSUER=http://keycloak:8080/realms/mooder
OIDC_CLIENT_ID=mooder-desktop
OIDC_CLIENT_SECRET=change-me
